# ------------------------------------------------------------------
# Beacon dev configuration — SINGLE SOURCE OF TRUTH for local ports.
# Copy to `.env` (the dev runner does this automatically if missing).
# Change a port here and the backend, Vite proxy, and docs all follow.
# ------------------------------------------------------------------

# FastAPI backend (uvicorn)
BACKEND_PORT=8000

# React / Vite dev server
FRONTEND_PORT=5173

# VitePress documentation dev server
DOCS_PORT=5174

# Landing marketing site (Vite) — separate from the app
LANDING_PORT=5175

# Landing CTA overrides (optional). Defaults: docs → DOCS_PORT,
# download → GitHub releases, app → FRONTEND_PORT.
# VITE_DOWNLOAD_URL=https://github.com/nannndev/beacon/releases/latest
# VITE_APP_URL=http://localhost:5173
# VITE_SUPPORT_URL=https://buymeacoffee.com/ekaprasety8
# VITE_GITHUB_URL=https://github.com/nannndev/beacon
# VITE_DISCORD_URL=https://discord.gg/your-invite

# Aptabase anonymous usage analytics (desktop app only). Sent natively by the
# Rust plugin, so the app key lives in src-tauri (option_env! APTABASE_APP_KEY),
# not here. It's a client/ingest key — safe to ship; it can only SEND events.
# To use your own project, build with: APTABASE_APP_KEY=A-XX-... (cargo/tauri build).
